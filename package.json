{
  "name": "pi-fast-resume",
  "version": "1.0.0",
  "description": "Fast session picker for pi — reads headers + first messages from 16KB partial reads instead of full-file parsing",
  "type": "module",
  "author": "Tom X Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monotykamary/pi-fast-resume.git"
  },
  "homepage": "https://github.com/monotykamary/pi-fast-resume#readme",
  "bugs": {
    "url": "https://github.com/monotykamary/pi-fast-resume/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "resume",
    "session",
    "fast",
    "picker",
    "performance"
  ],
  "files": [
    "*.ts",
    "src/",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint:dead": "knip --no-gitignore"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.75.4",
    "@earendil-works/pi-tui": "0.75.4",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "knip": "6.14.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "pi": {
    "extensions": [
      "./fast-resume.ts"
    ]
  },
  "overrides": {
    "brace-expansion": "5.0.6"
  }
}
